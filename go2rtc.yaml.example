# Placecitivi Configuration
# Documentation: https://github.com/AlexxIT/go2rtc
#
# USAGE:
# 1. Copy this file to: config/go2rtc.yaml
# 2. Edit the settings as needed
# 3. Run: docker-compose up -d

api:
  listen: ":1984"
  # Uncomment to enable basic auth (recommended for production)
  # username: admin
  # password: change_me_to_strong_password

# Placecitivi CCTV Map Feature
cctv:
  enabled: true
  db_path: /config/cctv.sqlite
  # Default admin credentials: admin/admin (change after first login!)

# Logging
log:
  level: info  # debug, info, warn, error

# Optional: Define streams here or add via Admin UI
# streams:
#   cam1: rtsp://user:pass@192.168.1.100:554/stream1
#   cam2: rtsp://user:pass@192.168.1.101:554/stream1

# WebRTC configuration (optional)
# webrtc:
#   candidates:
#     - stun:stun.l.google.com:19302

# FFmpeg settings (optional)
# ffmpeg:
#   bin: ffmpeg
